# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{gradle.kts,gradle}]
indent_style = space
indent_size = 2

[*.properties]
indent_style = space
indent_size = 2
