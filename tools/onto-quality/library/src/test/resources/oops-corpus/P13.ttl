@prefix : <http://oops.linkeddata.es/data/testP13#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://oops.linkeddata.es/data/testP13> a owl:Ontology ;
    dc:creator "http://purl.org/net/mpoveda"^^xsd:anyURI ;
    dcterms:license "http://creativecommons.org/licenses/by/4.0/" ;
    rdfs:comment "Test for P13"@en .

:relationshipNoInverse a owl:ObjectProperty ;
    rdfs:label "Relationship with no inverse"@en ;
    rdfs:comment "Element involved in M1-P13 pattern A."@en .

:relationshipSuggestion1 a owl:ObjectProperty ;
    rdfs:label "relationship suggestion 1"@en ;
    rdfs:comment "Element involved in M1-P13 pattern B."@en ;
    rdfs:domain :ClassA ;
    rdfs:range :ClassB .

:relationshipSuggestion2 a owl:ObjectProperty ;
    rdfs:label "relationship suggestion 2"@en ;
    rdfs:comment "Element involved in M1-P13 pattern B."@en ;
    rdfs:domain :ClassB ;
    rdfs:range :ClassA .

:ClassA a owl:Class ;
    rdfs:label "ClassA"@en .

:ClassB a owl:Class ;
    rdfs:label "ClassB"@en .

