@prefix : <http://oops.linkeddata.es/data/testP19#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://oops.linkeddata.es/data/testP19> a owl:Ontology ;
    dc:creator "http://purl.org/net/mpoveda"^^xsd:anyURI ;
    dcterms:license "http://creativecommons.org/licenses/by/4.0/" ;
    rdfs:comment "Test for P19"@en .

:attributeDomainUnion a owl:DatatypeProperty ;
    rdfs:label "attributeDomainUnion"@en ;
    rdfs:comment "Element involved in M2-P13 pattern A."@en ;
    rdfs:domain :ClassA,
        :ClassB .

:attributeRangeUnion a owl:DatatypeProperty ;
    rdfs:label "attributeRangeUnion"@en ;
    rdfs:comment "Element involved in M2-P13 pattern B."@en ;
    rdfs:range rdfs:Literal,
        xsd:boolean .

:relationshipDomainUnion a owl:ObjectProperty ;
    rdfs:label "relationshipDomainUnion"@en ;
    rdfs:comment "Element involved in M1-P13 pattern A."@en ;
    rdfs:domain :ClassA,
        :ClassB .

:relationshipRangeUnion a owl:ObjectProperty ;
    rdfs:label "relationshipRangeUnion"@en ;
    rdfs:comment "Element involved in M1-P13 pattern B."@en ;
    rdfs:range :ClassA,
        :ClassB .

:ClassA a owl:Class ;
    rdfs:label "ClassA"@en .

:ClassB a owl:Class ;
    rdfs:label "ClassB"@en ;
    rdfs:subClassOf owl:Thing .

