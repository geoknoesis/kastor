@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/k01/a> a owl:Ontology ;
    rdfs:label "Module A"@en ;
    owl:imports <http://example.org/k01/b> .

<http://example.org/k01/b> a owl:Ontology ;
    rdfs:label "Module B"@en ;
    owl:imports <http://example.org/k01/a> .
