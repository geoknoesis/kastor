@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:   <http://purl.org/dc/elements/1.1/> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix :     <http://oops.linkeddata.es/data/testP21#> .

<http://oops.linkeddata.es/data/testP21> a owl:Ontology ;
    dc:creator "http://purl.org/net/mpoveda"^^xsd:anyURI ;
    dct:license <http://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "Test for P21"@en .

:MiscClass a owl:Class ;
    rdfs:label "Misc class"@en ;
    rdfs:subClassOf owl:Thing .

:MiscellaneaClass a owl:Class ;
    rdfs:label "Miscellanea class"@en ;
    rdfs:subClassOf owl:Thing .

:MiscellaneousClass a owl:Class ;
    rdfs:label "Miscellaneous class"@en ;
    rdfs:subClassOf owl:Thing .

:MiscellanyClass a owl:Class ;
    rdfs:label "Miscellany class"@en ;
    rdfs:subClassOf owl:Thing .

:OtherClass a owl:Class ;
    rdfs:label "Other class"@en .
