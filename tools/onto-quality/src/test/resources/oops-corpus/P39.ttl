@prefix : <http://oops.linkeddata.es/data/testP39#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:ClassA a owl:Class ;
    rdfs:label "ClassA"@en ;
    rdfs:comment "This element just provides some content. The ontology is involved in M1-P39."@en .

[] a owl:Ontology ;
    dc:creator "http://purl.org/net/mpoveda"^^xsd:anyURI ;
    dcterms:license "http://creativecommons.org/licenses/by/4.0/" ;
    rdfs:comment "Test for P39"@en .

