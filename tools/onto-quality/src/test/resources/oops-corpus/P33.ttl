@prefix : <http://oops.linkeddata.es/data/testP33#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://oops.linkeddata.es/data/testP33> a owl:Ontology ;
    dc:creator "http://purl.org/net/mpoveda"^^xsd:anyURI ;
    dcterms:license "http://creativecommons.org/licenses/by/4.0/" ;
    rdfs:comment "Test for P33"@en .

:relationshipT a owl:ObjectProperty ;
    rdfs:label "relationshipT"@en ;
    rdfs:comment "Element involved in M1-P33."@en ;
    owl:propertyChainAxiom ( :relationshipS ) .

:relationshipS a owl:ObjectProperty ;
    rdfs:label "relationshipS"@en ;
    rdfs:comment "Element involved in M1-P33."@en .

